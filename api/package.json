{
  "name": "puntlab-api",
  "version": "0.1.0",
  "private": true,
  "description": "Fastify REST API for exposing PuntLab recommendations, subscriptions, and admin surfaces.",
  "type": "module",
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "prisma:generate": "prisma generate"
  },
  "dependencies": {
    "@fastify/cookie": "11.0.2",
    "@fastify/cors": "11.2.0",
    "@paystack/paystack-sdk": "1.0.1",
    "@prisma/client": "7.6.0",
    "dotenv": "17.2.3",
    "fastify": "5.8.4"
  },
  "devDependencies": {
    "@types/node": "25.5.2",
    "prisma": "7.6.0",
    "tsx": "4.21.0",
    "typescript": "6.0.2"
  }
}
