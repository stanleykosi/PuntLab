# Canonical environment template for the PuntLab Python agent.
# Scope: includes every environment-backed setting read by `agent/src/config.py`.
# Dependencies: copy to `agent/.env` before running the agent locally or in deployment.

# === Agent Runtime ===
APP_NAME=puntlab-agent
ENVIRONMENT=development
LOG_LEVEL=INFO
PIPELINE_START_HOUR=7
PUBLISH_HOUR=10
BOOTSTRAP_HEARTBEAT_SECONDS=300

# === LLM Providers ===
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...
OPENROUTER_API_KEY=sk-or-...
LLM_PRIMARY_PROVIDER=openrouter
LLM_SECONDARY_PROVIDER=openai
LLM_FALLBACK_PROVIDER=anthropic
LLM_PRIMARY_MODEL=qwen/qwen3.6-plus:free
LLM_SECONDARY_MODEL=gpt-4o
LLM_FALLBACK_MODEL=claude-sonnet-4-20250514

# === Data Providers ===
API_FOOTBALL_KEY=
BALLDONTLIE_API_KEY=
TAVILY_API_KEY=tvly-...

# === Database ===
DATABASE_URL=postgresql://puntlab:puntlab@localhost:5432/puntlab
SUPABASE_URL=https://xxx.supabase.co
SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_KEY=eyJ...

# === Redis ===
REDIS_URL=redis://localhost:6379/0

# === Telegram ===
TELEGRAM_BOT_TOKEN=123456:ABC-...
ADMIN_TELEGRAM_IDS=123456789,987654321

# === Payments ===
PAYSTACK_SECRET_KEY=sk_live_...
PAYSTACK_PUBLIC_KEY=pk_live_...
PAYSTACK_WEBHOOK_SECRET=

# === Observability ===
LANGFUSE_PUBLIC_KEY=pk-lf-...
LANGFUSE_SECRET_KEY=sk-lf-...
LANGFUSE_HOST=https://cloud.langfuse.com
