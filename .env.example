# Canonical local environment template for PuntLab.
# Scope: captures all environment variables defined in Section 22 of the
# technical spec, plus the local Docker Compose variables required to run them.
# Dependencies: copied to `.env` before local development or deployment setup.

# === Local Docker Compose ===
POSTGRES_DB=puntlab
POSTGRES_USER=puntlab
POSTGRES_PASSWORD=puntlab
POSTGRES_PORT=5432
REDIS_PORT=6379
API_PORT=3001
WEB_PORT=3000
NEXT_PUBLIC_API_URL=http://localhost:3001
NEXT_PUBLIC_SUPABASE_URL=https://xxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...

# === LLM Providers ===
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...
OPENROUTER_API_KEY=sk-or-...

# === Data Providers ===
API_FOOTBALL_KEY=
FOOTBALL_DATA_API_KEY=
THE_ODDS_API_KEY=
BALLDONTLIE_API_KEY=
TAVILY_API_KEY=tvly-...

# === Supabase ===
SUPABASE_URL=https://xxx.supabase.co
SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_KEY=eyJ...
DATABASE_URL=postgresql://puntlab:puntlab@postgres:5432/puntlab

# === Redis ===
REDIS_URL=redis://redis:6379/0

# === Telegram ===
TELEGRAM_BOT_TOKEN=123456:ABC-...
ADMIN_TELEGRAM_IDS=123456789,987654321

# === Payments ===
PAYSTACK_SECRET_KEY=sk_live_...
PAYSTACK_PUBLIC_KEY=pk_live_...
PAYSTACK_WEBHOOK_SECRET=

# === Observability ===
LANGFUSE_PUBLIC_KEY=pk-lf-...
LANGFUSE_SECRET_KEY=sk-lf-...
LANGFUSE_HOST=https://cloud.langfuse.com

# === App Config ===
PIPELINE_START_HOUR=7
PUBLISH_HOUR=10
ENVIRONMENT=development
LOG_LEVEL=INFO
